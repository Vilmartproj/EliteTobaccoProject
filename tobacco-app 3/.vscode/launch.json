{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Elite Tobacco Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server/index.js",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "restart": true
    },
    {
      "name": "Launch Chrome (Vite Dev)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Server + Chrome)",
      "configurations": ["Launch Elite Tobacco Server", "Launch Chrome (Vite Dev)"]
    }
  ]
}

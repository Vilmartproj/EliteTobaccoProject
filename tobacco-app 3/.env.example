# Elite Tobacco backend environment template
# Copy this file to .env and fill values during deployment.

PORT=3001
# Do not set NODE_ENV in Vite env files.
# Set NODE_ENV in npm scripts / PM2 runtime config.

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=EliteTobacco
DB_CONNECTION_LIMIT=10
DB_AUTO_CREATE=false
DB_CLEAN_SETUP=false

# Admin Configuration
# IMPORTANT: Change these values in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_in_production
